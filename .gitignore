# --- Build output -----------------------------------------------------------
# The compiler, all emberc variants, object files and archives. ~21 MB, fully
# regenerated by `make`.
build/

# Stray object files / archives / debug bundles outside build/ (defensive;
# none are tracked today, this just stops accidental commits).
*.o
*.a
*.dSYM/

# --- macOS ------------------------------------------------------------------
.DS_Store

# --- Editor extensions ------------------------------------------------------
# VS Code extension npm deps — regenerated by `npm install`.
editors/vscode/node_modules/

# Zed grammar. The grammar source is its OWN published repo
# (github.com/kmcnally5/tree-sitter-ember), which Zed clones at the pinned rev in
# editors/zed/extension.toml. `tree-sitter-ember/` here is the local working clone
# of that repo and `grammars/ember/` is Zed's derived fetch-cache — neither belongs
# in this repo (decision: separate published grammar repo; see docs/architecture.md).
editors/zed/tree-sitter-ember/
editors/zed/grammars/ember/

# Compiled Zed extension wasm + the prebuilt grammar wasm cache — built on install.
editors/zed/*.wasm
editors/zed/grammars/*.wasm

# --- Local / per-user -------------------------------------------------------
# Per-user Claude Code settings (not shared).
.claude/settings.local.json

# Private/scratch app code (the dir name was historically used for unpublished
# work; defensive so nothing under it is ever committed by accident).
non-public/

# Stray scratch C file at the repo root — a malloc/Student demo, not part of
# Ember. Ignored so it can't pollute history; safe to delete.
/example.c

# Note: tests/trace/*.tape are GOLDEN test fixtures and are intentionally
# tracked — do not add a *.tape ignore rule.
