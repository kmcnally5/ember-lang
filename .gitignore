# --- Build output -----------------------------------------------------------
# The compiler, all emberc variants, object files and archives. ~21 MB, fully
# regenerated by `make`.
build/

# Stray object files / archives / debug bundles outside build/ (defensive;
# none are tracked today, this just stops accidental commits).
*.o
*.a
*.dSYM/

# --- macOS ------------------------------------------------------------------
.DS_Store

# --- Editor extensions ------------------------------------------------------
# VS Code extension npm deps — regenerated by `npm install`.
editors/vscode/node_modules/

# Zed grammar. `tree-sitter-ember/` is its own local git repo (the grammar
# source); `grammars/ember/` is a fetch-clone of it (a derived cache, like
# node_modules). Both are kept out of this repo's first commit. TODO (at push
# time): decide whether the grammar becomes a git submodule pointing at its own
# GitHub repo, or is vendored in directly.
editors/zed/tree-sitter-ember/
editors/zed/grammars/ember/

# Compiled Zed extension wasm — built from editors/zed/src by Zed on install.
editors/zed/*.wasm

# --- Local / per-user -------------------------------------------------------
# Per-user Claude Code settings (not shared).
.claude/settings.local.json

# Stray scratch C file at the repo root — a malloc/Student demo, not part of
# Ember. Ignored so it can't pollute history; safe to delete.
/example.c

# Note: tests/trace/*.tape are GOLDEN test fixtures and are intentionally
# tracked — do not add a *.tape ignore rule.
