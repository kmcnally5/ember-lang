== fn add (arity 2) ==
0000    3  GET_LOCAL 0
0002    |  GET_LOCAL 1
0004    |  ADD      0
0006    |  RETURN  
0007    |  CONST    0  (= 0)
0009    |  RETURN  
== fn main (arity 0) ==
0000    6  CONST    0  (= 2)
0002    |  CONST    1  (= 3)
0004    |  CALL     0 2
0007    |  RETURN  
0008    |  CONST    2  (= 0)
0010    |  RETURN  
