Program
  Fn flow
    params:
      x: int
    body:
      If
        cond:
          Binary LT
            Ident x
            Int 0
        then:
          Return
            (unit)
        else:
          If
            cond:
              Binary EQ
                Ident x
                Int 0
            then:
              Loop
                Break
            else:
              Block
                For i
                  iter:
                    Array (3)
                      Int 1
                      Int 2
                      Int 3
                  body:
                    Continue
      Match
        value:
          Ident x
        case Some(v)
          Spawn
            Call
              callee:
                Ident work
              args:
                Ident v
        case None
          Nursery
            Spawn
              Call
                callee:
                  Ident a
            Spawn
              Call
                callee:
                  Ident b
